{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/session-start.sh",
            "name": "maestro-session-start",
            "description": "Initialize Maestro workspace and generate permissions manifest",
            "timeout": 15000
          }
        ]
      }
    ],
    "BeforeToolSelection": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/before-tool-selection.sh",
            "name": "maestro-tool-selection",
            "description": "UX optimization: suggest available tools based on active agent (NOT a security boundary)",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/before-tool.sh",
            "name": "maestro-before-tool",
            "description": "PRIMARY enforcement: blocks unauthorized tool calls and auto-detects subagent invocations",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/after-tool.sh",
            "name": "maestro-after-tool",
            "description": "Clear active agent tracking when subagent tool call completes",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/before-agent.sh",
            "name": "maestro-before-agent",
            "description": "Inject session context into agent turns",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/after-agent.sh",
            "name": "maestro-after-agent",
            "description": "Validate handoff report format with retry on malformed output",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/session-end.sh",
            "name": "maestro-session-end",
            "description": "Clean up temporary state files",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
