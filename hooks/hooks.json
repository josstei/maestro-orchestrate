{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js gemini session-start",
            "name": "maestro-session-start",
            "description": "Initialize hook state and prune stale sessions",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js qwen session-start",
            "name": "maestro-session-start-qwen",
            "description": "Initialize hook state and prune stale sessions (Qwen Code)",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js gemini before-agent",
            "name": "maestro-before-agent",
            "description": "Inject session context into agent turns",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js qwen before-agent",
            "name": "maestro-before-agent-qwen",
            "description": "Inject session context into agent turns (Qwen Code)",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js gemini after-agent",
            "name": "maestro-after-agent",
            "description": "Validate handoff report format with retry on malformed output",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js qwen after-agent",
            "name": "maestro-after-agent-qwen",
            "description": "Validate handoff report format with retry on malformed output (Qwen Code)",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js gemini session-end",
            "name": "maestro-session-end",
            "description": "Clean up hook state for ended session",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/hook-runner.js qwen session-end",
            "name": "maestro-session-end-qwen",
            "description": "Clean up hook state for ended session (Qwen Code)",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
