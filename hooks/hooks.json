{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/session-start.sh",
            "name": "maestro-session-start",
            "description": "Initialize Maestro workspace state directory for the session",
            "timeout": 15000
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/before-model.sh",
            "name": "maestro-model-override",
            "description": "Reserved for future config overrides — model overrides only work via parallel dispatch --model flag",
            "timeout": 3000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/before-agent.sh",
            "name": "maestro-before-agent",
            "description": "Inject session context into agent turns",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/after-agent.sh",
            "name": "maestro-after-agent",
            "description": "Validate handoff report format with retry on malformed output",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/session-end.sh",
            "name": "maestro-session-end",
            "description": "Clean up temporary state files",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
